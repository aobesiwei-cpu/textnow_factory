# ============================================
# SQLite configuration (recommended for development and small-scale deployment)
# ============================================
DB_TYPE=sqlite
SQLITE_PATH=./data/textnow_factory.db

# If you need to use MySQL, please refer to the configuration below
# DB_TYPE=mysql
# DB_HOST=your_db_host
# DB_PORT=3306
# DB_USER=your_username
# DB_PASS=your_password
# DB_NAME=textnow_us

# ============================================
# JWT authentication configuration
# ============================================
# In production, MUST be changed to a long random string
JWT_SECRET_KEY=CHANGE_THIS_TO_LONG_RANDOM_STR_2026_MINIMUM_32_CHARS
JWT_EXPIRE_HOURS=24

# ============================================
# Global business configuration
# ============================================
MAX_CONCURRENT_TASK=20
REQUEST_TIMEOUT=15
RETRY_TIMES=3
POLL_INTERVAL_SEC=10

# ============================================
# Proxy pool interface configuration (optional)
# ============================================
PROXY_API_URL=
PROXY_API_KEY=

# ============================================
# Flask configuration
# ============================================
FLASK_ENV=production
FLASK_DEBUG=0
